{
  "entities": {
    "Shop": {
      "title": "Shop",
      "description": "Represents a tailor shop (one per user).",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Shop name" },
        "phone": { "type": "string", "description": "Shop phone number" },
        "address": { "type": "string", "description": "Shop address" },
        "logoUrl": { "type": "string", "description": "URL to shop logo" },
        "invoiceFooter": { "type": "string", "description": "Custom message for invoice footer" },
        "enableWhatsappNotifications": { "type": "boolean", "description": "Toggle WhatsApp notifications" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdAt"]
    },
    "Staff": {
      "title": "Staff",
      "description": "Represents a staff/worker in the shop.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the staff member" },
        "phone": { "type": "string", "description": "Contact phone number" },
        "role": { "type": "string", "enum": ["stitcher", "cutter", "presser"], "description": "Job role" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "role", "createdAt"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A customer of a specific shop.",
      "type": "object",
      "properties": {
        "shopId": { "type": "string", "description": "ID of the shop this customer belongs to" },
        "name": { "type": "string", "description": "Customer name" },
        "phone": { "type": "string", "description": "Customer phone number (primary search key)" },
        "address": { "type": "string", "description": "Customer address" },
        "notes": { "type": "string", "description": "Additional notes" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["shopId", "name", "phone", "createdAt"]
    },
    "Measurement": {
      "title": "Measurement",
      "description": "Shalwar Kameez measurements for a customer.",
      "type": "object",
      "properties": {
        "shopId": { "type": "string" },
        "customerId": { "type": "string" },
        "kameezShoulder": { "type": "number" },
        "kameezChest": { "type": "number" },
        "kameezWaist": { "type": "number" },
        "kameezHip": { "type": "number" },
        "kameezLength": { "type": "number" },
        "kameezArmLength": { "type": "number" },
        "kameezArmWidth": { "type": "number" },
        "kameezCollarSize": { "type": "number" },
        "kameezFrontLength": { "type": "number" },
        "kameezBackLength": { "type": "number" },
        "kameezCuffSize": { "type": "number" },
        "shalwarWaist": { "type": "number" },
        "shalwarHip": { "type": "number" },
        "shalwarLength": { "type": "number" },
        "shalwarBottomWidth": { "type": "number" },
        "shalwarThighWidth": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["shopId", "customerId", "updatedAt"]
    },
    "Order": {
      "title": "Order",
      "description": "A tailoring order.",
      "type": "object",
      "properties": {
        "shopId": { "type": "string" },
        "tokenId": { "type": "string", "description": "Unique incremental or short code for tracking" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "phone": { "type": "string", "description": "Customer phone number" },
        "dressType": { "type": "string" },
        "measurements": { 
          "type": "object", 
          "description": "Detailed measurements for this specific order",
          "properties": {
            "length": { "type": "number" },
            "chest": { "type": "number" },
            "waist": { "type": "number" },
            "hip": { "type": "number" },
            "shoulder": { "type": "number" },
            "sleeve": { "type": "number" },
            "neck": { "type": "number" }
          }
        },
        "notificationLogs": {
          "type": "array",
          "description": "Logs of sent notifications (e.g. WhatsApp)",
          "items": { "type": "object" }
        },
        "assignedWorkerId": {
          "type": "string",
          "description": "ID of the staff handling the order"
        },
        "quantity": { "type": "number", "default": 1 },
        "rackLocation": { "type": "string", "description": "Physical location in the shop" },
        "notes": { "type": "string" },
        "deliveryDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Pending", "Stitching", "Ready", "Delivered"] },
        "price": { "type": "number" },
        "advancePayment": { "type": "number" },
        "paymentStatus": { "type": "string", "enum": ["Unpaid", "Partial", "Paid"] },
        "payments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "amount": { "type": "number" },
              "date": { "type": "string", "format": "date-time" },
              "method": { "type": "string" },
              "note": { "type": "string" }
            }
          }
        },
        "referencePhotoUrl": { "type": "string" },
        "sampleDesignUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["shopId", "tokenId", "customerName", "dressType", "status", "price", "createdAt", "updatedAt"]
    },
    "MeasurementTemplate": {
      "title": "MeasurementTemplate",
      "description": "Customizable measurement template for a shop.",
      "type": "object",
      "properties": {
        "nameEn": { "type": "string" },
        "nameUr": { "type": "string" },
        "unit": { "type": "string", "enum": ["inch", "cm"] },
        "gender": { "type": "string", "enum": ["male", "female", "kids"] },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "labelEn": { "type": "string" },
              "labelUr": { "type": "string" },
              "icon": { "type": "string" },
              "order": { "type": "number" }
            }
          }
        },
        "isDefault": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["nameEn", "fields", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "In-app notifications for overdue orders, status changes, etc.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "description": "Type of notification (e.g. order_overdue, order_ready)" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "orderId": { "type": "string" },
        "customerId": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "title", "message", "read", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile and role information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Article": {
      "title": "Article",
      "description": "CMS Article.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "content": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published"] },
        "language": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "status"]
    },
    "SocialPost": {
      "title": "SocialPost",
      "description": "Generated social media posts.",
      "type": "object",
      "properties": {
        "baseContent": { "type": "string" },
        "facebook": { "type": "string" },
        "instagram": { "type": "string" },
        "linkedin": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["baseContent"]
    },
    "MediaFile": {
      "title": "MediaFile",
      "description": "Uploaded media files.",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "name": { "type": "string" },
        "size": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["url", "name"]
    },
    "ChatChannel": {
      "title": "ChatChannel",
      "description": "A communication channel (thread) between tailor and customer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "lastMessageText": { "type": "string" },
        "lastMessageTime": { "type": "number" },
        "unreadCount": { "type": "number" },
        "shopId": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "customerName", "lastMessageText", "lastMessageTime", "unreadCount", "shopId", "createdAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A single message inside a communication channel.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderRole": { "type": "string", "enum": ["tailor", "customer"] },
        "text": { "type": "string" },
        "createdAt": { "type": "number" },
        "read": { "type": "boolean" },
        "orderId": { "type": "string" },
        "attachments": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "senderId", "senderRole", "text", "createdAt", "read"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and roles."
    },
    "/articles/{articleId}": {
      "schema": { "$ref": "#/entities/Article" },
      "description": "Stores CMS articles."
    },
    "/social_posts/{postId}": {
      "schema": { "$ref": "#/entities/SocialPost" },
      "description": "Stores generated social media posts."
    },
    "/media_library/{mediaId}": {
      "schema": { "$ref": "#/entities/MediaFile" },
      "description": "Stores media file metadata."
    },
    "/shops/{shopId}": {
      "schema": { "$ref": "#/entities/Shop" },
      "description": "Stores shop profiles. Document ID is the user's UID."
    },
    "/shops/{shopId}/customers/{customerId}": {
      "schema": { "$ref": "#/entities/Customer" },
      "description": "Stores customers for a specific shop."
    },
    "/shops/{shopId}/staff/{staffId}": {
      "schema": { "$ref": "#/entities/Staff" },
      "description": "Stores shop workers/staff."
    },
    "/shops/{shopId}/measurements/{measurementId}": {
      "schema": { "$ref": "#/entities/Measurement" },
      "description": "Stores customer measurements for a specific shop. Document ID is usually the customerId."
    },
    "/shops/{shopId}/measurementTemplates/{templateId}": {
      "schema": { "$ref": "#/entities/MeasurementTemplate" },
      "description": "Stores customizable measurement templates per shop."
    },
    "/shops/{shopId}/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Stores tailoring orders for a specific shop."
    },
    "/shops/{shopId}/notifications/{notificationId}": {
      "schema": { "$ref": "#/entities/Notification" },
      "description": "Stores user notifications for a specific shop."
    },
    "/chats/{channelId}": {
      "schema": { "$ref": "#/entities/ChatChannel" },
      "description": "Stores chat channel thread metadata."
    },
    "/chats/{channelId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/ChatMessage" },
      "description": "Stores messages within a specific chat channel."
    }
  }
}
