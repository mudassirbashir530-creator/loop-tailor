rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Primitives ---
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner() { 
      return isSignedIn() && (
        (resource != null && resource.data.userId == request.auth.uid) || 
        (resource != null && resource.data.createdBy == request.auth.uid)
      ); 
    }
    function isCreatingWithOwner() { 
      return isSignedIn() && (
        incoming().userId == request.auth.uid || 
        incoming().createdBy == request.auth.uid
      ); 
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /settings/{settingsId} {
      allow read, write: if isSignedIn() && request.auth.uid == settingsId;
    }

    match /customers/{docId} {
      allow read, delete: if isOwner();
      allow create: if isCreatingWithOwner();
      allow update: if isOwner() && (
        (incoming().userId == existing().userId) || 
        (incoming().createdBy == existing().createdBy)
      );
    }

    match /orders/{docId} {
      allow read, delete: if isOwner();
      allow create: if isCreatingWithOwner();
      allow update: if isOwner() && (
        (incoming().userId == existing().userId) || 
        (incoming().createdBy == existing().createdBy)
      );
    }

    match /invoices/{docId} {
      allow read, delete: if isOwner();
      allow create: if isCreatingWithOwner();
      allow update: if isOwner() && (
        (incoming().userId == existing().userId) || 
        (incoming().createdBy == existing().createdBy)
      );
    }

    match /workers/{workerId} {
      allow read: if isOwner();
      allow create: if isCreatingWithOwner();
      allow update: if isOwner() && incoming().userId == existing().userId;
      allow delete: if isOwner();
    }

    match /staff/{staffId} {
      allow read: if isOwner();
      allow create: if isCreatingWithOwner();
      allow update: if isOwner() && incoming().userId == existing().userId;
      allow delete: if isOwner();
    }

    match /measurementTemplates/{templateId} {
      allow read: if isOwner();
      allow create: if isCreatingWithOwner();
      allow update: if isOwner() && incoming().userId == existing().userId;
      allow delete: if isOwner();
    }

    match /orderTemplates/{templateId} {
      allow read: if isOwner();
      allow create: if isCreatingWithOwner();
      allow update: if isOwner() && incoming().userId == existing().userId;
      allow delete: if isOwner();
    }

    match /notifications/{notificationId} {
      allow read: if isOwner();
      allow create: if isCreatingWithOwner();
      allow update: if isOwner() && incoming().userId == existing().userId;
      allow delete: if isOwner();
    }

    match /measurements/{measurementId} {
      allow read: if isOwner();
      allow create: if isCreatingWithOwner();
      allow update: if isOwner() && incoming().userId == existing().userId;
      allow delete: if isOwner();
    }

    match /payments/{paymentId} {
      allow read: if isOwner();
      allow create: if isCreatingWithOwner();
      allow update: if isOwner() && incoming().userId == existing().userId;
      allow delete: if isOwner();
    }

    match /payroll/{payrollId} {
      allow read: if isOwner();
      allow create: if isCreatingWithOwner();
      allow update: if isOwner() && incoming().userId == existing().userId;
      allow delete: if isOwner();
    }

    match /fcmTokens/{tokenId} {
      allow read: if isOwner();
      allow create: if isCreatingWithOwner();
      allow update: if isOwner() && incoming().userId == existing().userId;
      allow delete: if isOwner();
    }

    // Legacy shops data keeping locked down except owners
    match /shops/{shopId} {
      allow read: if isSignedIn() && request.auth.uid == shopId;
      allow write: if isSignedIn() && request.auth.uid == shopId;
      match /{document=**} {
        allow read, write: if isSignedIn() && request.auth.uid == shopId;
      }
    }
  }
}
