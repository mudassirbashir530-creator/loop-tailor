rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: shops
    // Document ID: {shopId} (User UID)
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - phone: string (optional, < 50 chars)
    //   - address: string (optional, < 200 chars)
    //   - logoUrl: string (optional, < 1000 chars)
    //   - invoiceFooter: string (optional, < 500 chars)
    //   - createdAt: string (required, ISO 8601)
    //
    // Collection: customers
    // Document ID: {customerId}
    // Fields:
    //   - shopId: string (required, must match creator UID)
    //   - name: string (required, 1-100 chars)
    //   - phone: string (required, 1-50 chars)
    //   - address: string (optional, < 200 chars)
    //   - notes: string (optional, < 1000 chars)
    //   - createdAt: string (required, ISO 8601)
    //
    // Collection: measurements
    // Document ID: {measurementId}
    // Fields:
    //   - shopId: string (required)
    //   - customerId: string (required)
    //   - kameezShoulder: number (optional)
    //   ... other measurement fields (optional numbers)
    //   - updatedAt: string (required, ISO 8601)
    //
    // Collection: orders
    // Document ID: {orderId}
    // Fields:
    //   - shopId: string (required)
    //   - customerId: string (required)
    //   - customerName: string (required)
    //   - dressType: string (required)
    //   - status: string (required, enum: ["Pending", "Stitching", "Ready", "Delivered"])
    //   - price: number (required)
    //   - advancePayment: number (optional)
    //   - referencePhotoUrl: string (optional)
    //   - sampleDesignUrl: string (optional)
    //   - createdAt: string (required, ISO 8601)
    //   - updatedAt: string (required, ISO 8601)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(shopId) {
      return isAuthenticated() && request.auth.uid == shopId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.shopId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, min, max) {
      return request.resource.data[field] is string && 
             request.resource.data[field].size() >= min && 
             request.resource.data[field].size() <= max;
    }

    function isValidOptionalString(field, max) {
      return !(field in request.resource.data) || 
             (request.resource.data[field] is string && request.resource.data[field].size() <= max);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidShop(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 50)) &&
             (!('address' in data) || (data.address is string && data.address.size() <= 200)) &&
             (!('logoUrl' in data) || (data.logoUrl is string && data.logoUrl.size() <= 1000)) &&
             (!('invoiceFooter' in data) || (data.invoiceFooter is string && data.invoiceFooter.size() <= 500)) &&
             data.createdAt is string;
    }

    function isValidCustomer(data) {
      return data.shopId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.phone is string && data.phone.size() > 0 && data.phone.size() <= 50 &&
             (!('address' in data) || (data.address is string && data.address.size() <= 200)) &&
             (!('notes' in data) || (data.notes is string && data.notes.size() <= 1000)) &&
             data.createdAt is string;
    }

    function isValidMeasurement(data) {
      return data.shopId == request.auth.uid &&
             data.customerId is string &&
             data.updatedAt is string;
    }

    function isValidOrder(data) {
      return data.shopId == request.auth.uid &&
             data.tokenId is string &&
             data.customerName is string &&
             data.dressType is string &&
             data.status in ["Pending", "Stitching", "Ready", "Delivered"] &&
             data.price is number &&
             (!('phone' in data) || data.phone is string) &&
             (!('quantity' in data) || data.quantity is number) &&
             (!('rackLocation' in data) || data.rackLocation is string) &&
             (!('measurements' in data) || data.measurements is map) &&
             data.createdAt is string &&
             data.updatedAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /counters/{shopId} {
      allow read, write: if isOwner(shopId);
    }

    match /shops/{shopId} {
      allow read: if isOwner(shopId);
      allow create: if isOwner(shopId) && isValidShop(request.resource.data);
      allow update: if isOwner(shopId) && isValidShop(request.resource.data);
      allow delete: if false;
    }

    match /customers/{customerId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.shopId == request.auth.uid);
      allow create: if isAuthenticated() && isValidCustomer(request.resource.data);
      allow update: if isAuthenticated() && resource.data.shopId == request.auth.uid && isValidCustomer(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.shopId == request.auth.uid;
    }

    match /measurements/{measurementId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.shopId == request.auth.uid);
      allow create: if isAuthenticated() && isValidMeasurement(request.resource.data);
      allow update: if isAuthenticated() && resource.data.shopId == request.auth.uid && isValidMeasurement(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.shopId == request.auth.uid;
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.shopId == request.auth.uid);
      allow create: if isAuthenticated() && isValidOrder(request.resource.data);
      allow update: if isAuthenticated() && resource.data.shopId == request.auth.uid && isValidOrder(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.shopId == request.auth.uid;
    }
  }
}
