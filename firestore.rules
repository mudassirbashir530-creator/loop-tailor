rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: shops
    // Document ID: {shopId} (User UID)
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - phone: string (optional, < 50 chars)
    //   - address: string (optional, < 200 chars)
    //   - logoUrl: string (optional, < 1000 chars)
    //   - invoiceFooter: string (optional, < 500 chars)
    //   - createdAt: string (required, ISO 8601)
    //
    // Subcollection: shops/{shopId}/customers
    // Document ID: {customerId}
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - phone: string (required, 1-50 chars)
    //   - address: string (optional, < 200 chars)
    //   - notes: string (optional, < 1000 chars)
    //   - createdAt: string (required, ISO 8601)
    //
    // Subcollection: shops/{shopId}/measurements
    // Document ID: {measurementId} (usually same as customerId)
    // Fields:
    //   - customerId: string (required)
    //   - kameezShoulder: number (optional)
    //   ... other measurement fields (optional numbers)
    //   - updatedAt: string (required, ISO 8601)
    //
    // Subcollection: shops/{shopId}/orders
    // Document ID: {orderId}
    // Fields:
    //   - customerId: string (required)
    //   - customerName: string (required)
    //   - dressType: string (required)
    //   - status: string (required, enum: ["Pending", "Stitching", "Ready", "Delivered"])
    //   - price: number (required)
    //   - advancePayment: number (optional)
    //   - referencePhotoUrl: string (optional)
    //   - sampleDesignUrl: string (optional)
    //   - createdAt: string (required, ISO 8601)
    //   - updatedAt: string (required, ISO 8601)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(shopId) {
      return isAuthenticated() && request.auth.uid == shopId;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidShop(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 50)) &&
             (!('address' in data) || (data.address is string && data.address.size() <= 200)) &&
             (!('logoUrl' in data) || (data.logoUrl is string && data.logoUrl.size() <= 1000)) &&
             (!('invoiceFooter' in data) || (data.invoiceFooter is string && data.invoiceFooter.size() <= 500)) &&
             (data.createdAt is string || data.createdAt is timestamp);
    }

    function isValidCustomer(data, shopId) {
      return data.shopId == shopId &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.phone is string && data.phone.size() > 0 && data.phone.size() <= 50 &&
             (!('address' in data) || (data.address is string && data.address.size() <= 200)) &&
             (!('notes' in data) || (data.notes is string && data.notes.size() <= 1000)) &&
             (data.createdAt is string || data.createdAt is timestamp);
    }

    function isValidMeasurement(data, shopId) {
      return data.shopId == shopId &&
             data.customerId is string &&
             (data.updatedAt is string || data.updatedAt is timestamp);
    }

    function isValidOrder(data, shopId) {
      return data.shopId == shopId &&
             data.tokenId is string &&
             data.customerName is string &&
             data.dressType is string &&
             data.status in ["Pending", "Stitching", "Ready", "Delivered"] &&
             data.price is number &&
             (!('phone' in data) || data.phone is string) &&
             (!('quantity' in data) || data.quantity is number) &&
             (!('rackLocation' in data) || data.rackLocation is string) &&
             (!('measurements' in data) || data.measurements is map) &&
             (data.createdAt is string || data.createdAt is timestamp) &&
             (data.updatedAt is string || data.updatedAt is timestamp);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /counters/{shopId} {
      allow read, write: if isOwner(shopId);
    }

    match /shops/{shopId} {
      allow read: if isOwner(shopId);
      allow create: if isOwner(shopId) && isValidShop(request.resource.data);
      allow update: if isOwner(shopId) && isValidShop(request.resource.data);
      allow delete: if false;

      match /customers/{customerId} {
        allow read: if isOwner(shopId);
        allow create: if isOwner(shopId) && isValidCustomer(request.resource.data, shopId);
        allow update: if isOwner(shopId) && isValidCustomer(request.resource.data, shopId);
        allow delete: if isOwner(shopId);
      }

      match /measurements/{measurementId} {
        allow read: if isOwner(shopId);
        allow create: if isOwner(shopId) && isValidMeasurement(request.resource.data, shopId);
        allow update: if isOwner(shopId) && isValidMeasurement(request.resource.data, shopId);
        allow delete: if isOwner(shopId);
      }

      match /orders/{orderId} {
        allow read: if isOwner(shopId);
        allow create: if isOwner(shopId) && isValidOrder(request.resource.data, shopId);
        allow update: if isOwner(shopId) && isValidOrder(request.resource.data, shopId);
        allow delete: if isOwner(shopId);
      }
    }
  }
}
