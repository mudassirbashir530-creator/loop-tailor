rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Primitives ---
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner() { return isSignedIn() && resource.data.userId == request.auth.uid; }
    function isCreatingWithOwner() { return isSignedIn() && incoming().userId == request.auth.uid; }
    
    // Admin check relies on the user document having role == 'admin'
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- Entity Validators ---

    function isTime(val) {
      return val is timestamp || val is string;
    }

    // --- Collections ---

    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      allow write: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    match /settings/{settingsId} {
      allow read: if isSignedIn() && request.auth.uid == settingsId;
      allow write: if isSignedIn() && request.auth.uid == settingsId;
    }

    match /customers/{customerId} {
      allow read: if isOwner();
      allow create: if isCreatingWithOwner();
      allow update: if isOwner() && incoming().userId == existing().userId;
      allow delete: if isOwner();
    }

    match /orders/{orderId} {
      allow read: if isOwner();
      allow create: if isCreatingWithOwner();
      allow update: if isOwner() && incoming().userId == existing().userId;
      allow delete: if isOwner();
    }

    match /workers/{workerId} {
      allow read: if isOwner();
      allow create: if isCreatingWithOwner();
      allow update: if isOwner() && incoming().userId == existing().userId;
      allow delete: if isOwner();
    }

    match /staff/{staffId} {
      allow read: if isOwner();
      allow create: if isCreatingWithOwner();
      allow update: if isOwner() && incoming().userId == existing().userId;
      allow delete: if isOwner();
    }

    match /measurementTemplates/{templateId} {
      allow read: if isOwner();
      allow create: if isCreatingWithOwner();
      allow update: if isOwner() && incoming().userId == existing().userId;
      allow delete: if isOwner();
    }

    match /orderTemplates/{templateId} {
      allow read: if isOwner();
      allow create: if isCreatingWithOwner();
      allow update: if isOwner() && incoming().userId == existing().userId;
      allow delete: if isOwner();
    }

    match /notifications/{notificationId} {
      allow read: if isOwner();
      allow create: if isCreatingWithOwner();
      allow update: if isOwner() && incoming().userId == existing().userId;
      allow delete: if isOwner();
    }

    match /measurements/{measurementId} {
      allow read: if isOwner();
      allow create: if isCreatingWithOwner();
      allow update: if isOwner() && incoming().userId == existing().userId;
      allow delete: if isOwner();
    }

    match /payments/{paymentId} {
      allow read: if isOwner();
      allow create: if isCreatingWithOwner();
      allow update: if isOwner() && incoming().userId == existing().userId;
      allow delete: if isOwner();
    }

    match /payroll/{payrollId} {
      allow read: if isOwner();
      allow create: if isCreatingWithOwner();
      allow update: if isOwner() && incoming().userId == existing().userId;
      allow delete: if isOwner();
    }

    match /fcmTokens/{tokenId} {
      allow read: if isOwner();
      allow create: if isCreatingWithOwner();
      allow update: if isOwner() && incoming().userId == existing().userId;
      allow delete: if isOwner();
    }

    // Legacy shops data keeping locked down except owners
    match /shops/{shopId} {
      allow read: if isSignedIn() && request.auth.uid == shopId;
      allow write: if isSignedIn() && request.auth.uid == shopId;
      match /{document=**} {
        allow read, write: if isSignedIn() && request.auth.uid == shopId;
      }
    }
  }
}
