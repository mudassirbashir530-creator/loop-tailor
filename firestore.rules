rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Primitives ---
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(shopId) { return isSignedIn() && request.auth.uid == shopId; }
    
    // Admin check relies on the user document having role == 'admin'
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- Entity Validators ---

    function isTime(val) {
      return val is timestamp || val is string;
    }

    function isValidUser(data) {
      return data.size() >= 3
        && data.uid is string && data.uid.size() <= 128
        && data.email is string && data.email.size() <= 255
        && data.role in ['user', 'admin']
        && (!data.keys().hasAll(['name']) || (data.name is string && data.name.size() <= 100))
        && (!data.keys().hasAll(['phone']) || data.phone is string)
        && (!data.keys().hasAll(['photoURL']) || data.photoURL is string)
        && (!data.keys().hasAll(['provider']) || data.provider is string)
        && (!data.keys().hasAll(['preferred_language']) || data.preferred_language is string)
        && (!data.keys().hasAll(['createdAt']) || isTime(data.createdAt));
    }

    function isValidArticle(data) {
      return data.size() >= 3
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.slug is string && data.slug.size() > 0 && data.slug.size() <= 200
        && data.status in ['draft', 'published']
        && (!data.keys().hasAll(['content']) || (data.content is string && data.content.size() <= 50000))
        && (!data.keys().hasAll(['language']) || (data.language is string && data.language.size() <= 10))
        && (!data.keys().hasAll(['createdAt']) || isTime(data.createdAt))
        && (!data.keys().hasAll(['updatedAt']) || isTime(data.updatedAt));
    }

    function isValidSocialPost(data) {
      return data.size() >= 1
        && data.baseContent is string && data.baseContent.size() <= 5000
        && (!data.keys().hasAll(['facebook']) || (data.facebook is string && data.facebook.size() <= 5000))
        && (!data.keys().hasAll(['instagram']) || (data.instagram is string && data.instagram.size() <= 5000))
        && (!data.keys().hasAll(['linkedin']) || (data.linkedin is string && data.linkedin.size() <= 5000))
        && (!data.keys().hasAll(['createdAt']) || isTime(data.createdAt));
    }

    function isValidMediaFile(data) {
      return data.size() >= 2
        && data.url is string && data.url.size() <= 1000
        && data.name is string && data.name.size() <= 500
        && (!data.keys().hasAll(['size']) || data.size is number)
        && (!data.keys().hasAll(['createdAt']) || isTime(data.createdAt));
    }

    function isValidCustomer(data) {
      return data.size() >= 3
        && data.shopId is string && data.shopId.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.phone is string && data.phone.size() <= 50
        && (!data.keys().hasAll(['address']) || (data.address is string && data.address.size() <= 1000))
        && (!data.keys().hasAll(['notes']) || (data.notes is string && data.notes.size() <= 2000))
        && (!data.keys().hasAll(['createdAt']) || isTime(data.createdAt))
        && (!data.keys().hasAll(['updatedAt']) || isTime(data.updatedAt));
    }

    // A simplified order validator
    function isValidOrder(data) {
       return data.size() >= 5
         && data.shopId is string
         && data.tokenId is string && data.tokenId.size() <= 50
         && data.customerName is string && data.customerName.size() <= 200
         && data.status in ['Pending', 'Stitching', 'Ready', 'Delivered']
         && data.price is number
         && (!data.keys().hasAll(['customerId']) || data.customerId is string)
         && (!data.keys().hasAll(['phone']) || data.phone is string)
         && (!data.keys().hasAll(['dressType']) || data.dressType is string)
         && (!data.keys().hasAll(['measurements']) || data.measurements is map)
         && (!data.keys().hasAll(['notificationLogs']) || (data.notificationLogs is list && data.notificationLogs.size() <= 100))
         && (!data.keys().hasAll(['assignedWorkerId']) || data.assignedWorkerId is string)
         && (!data.keys().hasAll(['assignedStaffId']) || data.assignedStaffId is string)
         && (!data.keys().hasAll(['assignedStaffName']) || data.assignedStaffName is string)
         && (!data.keys().hasAll(['quantity']) || data.quantity is number)
         && (!data.keys().hasAll(['rackLocation']) || data.rackLocation is string)
         && (!data.keys().hasAll(['notes']) || data.notes is string)
         && (!data.keys().hasAll(['deliveryDate']) || isTime(data.deliveryDate))
         && (!data.keys().hasAll(['advancePayment']) || data.advancePayment is number)
         && (!data.keys().hasAll(['paymentStatus']) || data.paymentStatus in ['Unpaid', 'Partial', 'Paid'])
         && (!data.keys().hasAll(['payments']) || (data.payments is list && data.payments.size() <= 50))
         && (!data.keys().hasAll(['referencePhotoUrl']) || data.referencePhotoUrl is string)
         && (!data.keys().hasAll(['sampleDesignUrl']) || data.sampleDesignUrl is string)
         && (!data.keys().hasAll(['createdAt']) || isTime(data.createdAt))
         && (!data.keys().hasAll(['updatedAt']) || isTime(data.updatedAt))
         && (!data.keys().hasAll(['lastNotifiedDate']) || data.lastNotifiedDate is string);
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // Admin dashboard requires listing users
      allow list: if isAdmin();
      
      allow create: if isSignedIn() && request.auth.uid == userId 
             && isValidUser(incoming())
             && incoming().uid == request.auth.uid
             // Prevent self-claiming admin on create
             && incoming().role == 'user';
             
      allow update: if isSignedIn() && (
             (request.auth.uid == userId 
             && isValidUser(incoming())
             && incoming().uid == existing().uid
             && incoming().role == existing().role)
             || isAdmin()
             );
             
      allow delete: if isAdmin();
    }

    match /subscriptions/{subId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /adminLogs/{logId} {
      allow read, write: if isAdmin();
    }

    match /articles/{articleId} {
      allow read: if (resource.data.status == 'published') || isAdmin();
      allow create, update, delete: if isAdmin(); // Only admins can create/update articles
    }

    match /social_posts/{postId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /media_library/{mediaId} {
      allow read: if true; // Media is public
      allow create, update, delete: if isAdmin();
    }

    match /counters/{shopId} {
      allow read, write: if isOwner(shopId);
    }

    match /shops/{shopId} {
      allow read: if isOwner(shopId);
      // Wait, user might need to create a shop document. Does `settings.tsx` create it?
      // For now, allow create/update if they own it.
      allow create, update: if isOwner(shopId);
      allow delete: if isOwner(shopId);

      match /customers/{customerId} {
        allow read: if isOwner(shopId);
        allow create: if isOwner(shopId) && isValidCustomer(incoming());
        allow update: if isOwner(shopId) && isValidCustomer(incoming())
                   && incoming().shopId == existing().shopId
                   && incoming().createdAt == existing().createdAt;
        allow delete: if isOwner(shopId);
      }
      
      match /measurements/{measurementId} {
        allow read, write: if isOwner(shopId); 
      }
      
      match /orders/{orderId} {
        allow read: if isOwner(shopId);
        allow create: if isOwner(shopId) && isValidOrder(incoming());
        allow update: if isOwner(shopId) && isValidOrder(incoming())
                   && incoming().shopId == existing().shopId
                   && incoming().createdAt == existing().createdAt;
        allow delete: if isOwner(shopId);
      }
      
      match /orderTemplates/{templateId} {
        allow read, write: if isOwner(shopId);
      }
      
      match /measurementTemplates/{templateId} {
        allow read, write: if isOwner(shopId);
      }
      
      match /payments/{paymentId} {
        allow read, write: if isOwner(shopId);
      }
      
      match /notifications/{notificationId} {
        allow read, write: if isOwner(shopId);
      }
      
      match /fcmTokens/{tokenId} {
        allow read, write: if isOwner(shopId);
      }
      
      match /staff/{staffId} {
        allow read, write: if isOwner(shopId);
      }

      match /payroll/{payrollId} {
        allow read, write: if isOwner(shopId);
      }
    }
  }
}
