rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /settings/{settingsId} {
      allow read, write: if isSignedIn() && request.auth.uid == settingsId;
    }

    match /shops/{shopId} {
      allow read, write: if isSignedIn() && request.auth.uid == shopId;
      match /{document=**} {
        allow read, write: if isSignedIn() && request.auth.uid == shopId;
      }
    }

    match /customers/{docId} {
      allow read, update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.createdBy == request.auth.uid);
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || request.resource.data.createdBy == request.auth.uid);
    }

    match /orders/{docId} {
      allow read, update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.createdBy == request.auth.uid);
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || request.resource.data.createdBy == request.auth.uid);
    }

    match /invoices/{docId} {
      allow read, update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.createdBy == request.auth.uid);
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || request.resource.data.createdBy == request.auth.uid);
    }

    match /workers/{docId} {
      allow read, update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.createdBy == request.auth.uid);
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || request.resource.data.createdBy == request.auth.uid);
    }

    match /staff/{docId} {
      allow read, update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.createdBy == request.auth.uid);
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || request.resource.data.createdBy == request.auth.uid);
    }

    match /measurementTemplates/{docId} {
      allow read, update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.createdBy == request.auth.uid);
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || request.resource.data.createdBy == request.auth.uid);
    }

    match /orderTemplates/{docId} {
      allow read, update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.createdBy == request.auth.uid);
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || request.resource.data.createdBy == request.auth.uid);
    }

    match /notifications/{docId} {
      allow read, update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.createdBy == request.auth.uid);
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || request.resource.data.createdBy == request.auth.uid);
    }

    match /measurements/{docId} {
      allow read, update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.createdBy == request.auth.uid);
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || request.resource.data.createdBy == request.auth.uid);
    }

    match /payments/{docId} {
      allow read, update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.createdBy == request.auth.uid);
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || request.resource.data.createdBy == request.auth.uid);
    }

    match /payroll/{docId} {
      allow read, update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.createdBy == request.auth.uid);
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || request.resource.data.createdBy == request.auth.uid);
    }

    match /fcmTokens/{docId} {
      allow read, update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.createdBy == request.auth.uid);
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || request.resource.data.createdBy == request.auth.uid);
    }
  }
}
